{
  "name": "onside-mam",
  "version": "0.1.0",
  "private": true,
  "description": "Media Asset Management system for Onside Productions",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:push": "npm run db:push --workspace=apps/api",
    "db:studio": "npm run db:studio --workspace=apps/api"
  },
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "turbo": "^2.9.3"
  }
}
