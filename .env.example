# Database
DATABASE_URL=postgresql://onside:onside@localhost:5432/onside_mam

# Redis
REDIS_URL=redis://localhost:6379

# Wasabi S3
WASABI_ACCESS_KEY_ID=your-access-key
WASABI_SECRET_ACCESS_KEY=your-secret-key
WASABI_REGION=eu-west-2
WASABI_BUCKET=onside-mam
WASABI_ENDPOINT=https://s3.eu-west-2.wasabisys.com
# Optional: public CDN URL for cacheable assets (thumbnails, proxies, HLS).
# When set, those URLs are served from the CDN instead of signed Wasabi URLs.
# Leave empty to keep signed-URL behavior.
# Example: WASABI_PUBLIC_URL=https://onside-mam.weareonside.com
WASABI_PUBLIC_URL=

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Auth
AUTH_SECRET=generate-a-random-secret-here
AUTH_URL=http://localhost:3000

# App
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development
